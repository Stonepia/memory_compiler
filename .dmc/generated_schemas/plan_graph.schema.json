{
  "$defs": {
    "PlanNode": {
      "additionalProperties": true,
      "description": "A single node in an executable plan graph.",
      "properties": {
        "agent": {
          "additionalProperties": true,
          "title": "Agent",
          "type": "object"
        },
        "context_refs": {
          "items": {
            "type": "string"
          },
          "title": "Context Refs",
          "type": "array"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "evidence_contract": {
          "additionalProperties": true,
          "title": "Evidence Contract",
          "type": "object"
        },
        "goal": {
          "title": "Goal",
          "type": "string"
        },
        "human_review": {
          "additionalProperties": true,
          "title": "Human Review",
          "type": "object"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "inputs": {
          "additionalProperties": true,
          "title": "Inputs",
          "type": "object"
        },
        "outputs": {
          "additionalProperties": true,
          "title": "Outputs",
          "type": "object"
        },
        "success_criteria": {
          "items": {
            "type": "string"
          },
          "title": "Success Criteria",
          "type": "array"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        },
        "type": {
          "enum": [
            "brief",
            "inspect",
            "plan",
            "edit",
            "test",
            "benchmark",
            "profile",
            "review",
            "decide",
            "distill"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "goal",
        "dependencies",
        "success_criteria"
      ],
      "title": "PlanNode",
      "type": "object"
    },
    "TaskRequest": {
      "additionalProperties": true,
      "description": "A request to work on a task. Aligned with ``examples/sample_task.yaml``.",
      "properties": {
        "budget_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget Tokens"
        },
        "changed_files": {
          "items": {
            "type": "string"
          },
          "title": "Changed Files",
          "type": "array"
        },
        "constraints": {
          "items": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "current_phase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Phase"
        },
        "hardware": {
          "items": {
            "type": "string"
          },
          "title": "Hardware",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo"
        },
        "task": {
          "title": "Task",
          "type": "string"
        }
      },
      "required": [
        "id",
        "task"
      ],
      "title": "TaskRequest",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "An editable execution graph over plan nodes.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/PlanNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "task": {
      "$ref": "#/$defs/TaskRequest"
    }
  },
  "required": [
    "id",
    "task",
    "nodes"
  ],
  "title": "PlanGraph",
  "type": "object"
}
