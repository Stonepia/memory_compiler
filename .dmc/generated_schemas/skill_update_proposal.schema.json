{
  "$defs": {
    "EvidenceRef": {
      "additionalProperties": true,
      "description": "A pointer to supporting evidence (artifact, file, event, ...).",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "uri"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": true,
      "description": "Where a piece of memory came from.\n\nAccepts either a structured mapping or a bare URI string (which is coerced\ninto ``{\"source\": <uri>}``). ``source`` must be a known-scheme URI.",
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "source"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "A pending change to a workflow/atom/knowledge object.",
  "properties": {
    "change_kind": {
      "enum": [
        "create",
        "update",
        "deprecate"
      ],
      "title": "Change Kind",
      "type": "string"
    },
    "diff_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Diff Summary"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "provenance": {
      "items": {
        "$ref": "#/$defs/Provenance"
      },
      "minItems": 1,
      "title": "Provenance",
      "type": "array"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "status": {
      "default": "pending",
      "enum": [
        "pending",
        "accepted",
        "rejected"
      ],
      "title": "Status",
      "type": "string"
    },
    "target": {
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "id",
    "target",
    "change_kind",
    "rationale",
    "provenance"
  ],
  "title": "SkillUpdateProposal",
  "type": "object"
}
