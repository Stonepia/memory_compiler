{
  "$defs": {
    "Provenance": {
      "additionalProperties": true,
      "description": "Where a piece of memory came from.\n\nAccepts either a structured mapping or a bare URI string (which is coerced\ninto ``{\"source\": <uri>}``). ``source`` must be a known-scheme URI.",
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "source"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "A raw artifact summary and its URI.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "title": "Kind",
      "type": "string"
    },
    "metrics": {
      "additionalProperties": true,
      "title": "Metrics",
      "type": "object"
    },
    "provenance": {
      "items": {
        "$ref": "#/$defs/Provenance"
      },
      "minItems": 1,
      "title": "Provenance",
      "type": "array"
    },
    "raw_artifact_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Artifact Path"
    },
    "raw_artifact_uri": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Artifact Uri"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "uri": {
      "title": "Uri",
      "type": "string"
    }
  },
  "required": [
    "id",
    "uri",
    "kind",
    "summary",
    "provenance"
  ],
  "title": "ArtifactCard",
  "type": "object"
}
