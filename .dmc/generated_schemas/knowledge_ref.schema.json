    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "uri": {
      "title": "Uri",
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "uri",
    "summary",
    "provenance"
  ],
  "title": "KnowledgeRef",
  "type": "object"
