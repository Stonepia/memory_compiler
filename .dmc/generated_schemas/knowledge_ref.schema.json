      "additionalProperties": true,
      "description": "Where a piece of memory came from.\n\nAccepts either a structured mapping or a bare URI string (which is coerced\ninto ``{\"source\": <uri>}``). ``source`` must be a known-scheme URI.",
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "source"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "A fact/spec/doc/code reference with provenance.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "kind": {
